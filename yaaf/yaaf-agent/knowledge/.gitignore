# knowledge/raw/source/ is generated by `npm run kb:extract` — no need to commit
raw/source/

# Lint report is ephemeral
.kb-lint-report.json

# Differential compilation manifest — tracks raw-file hashes for incremental builds.
# Do NOT commit: CI always clones fresh, so committed hashes would cause false cache hits.
.kb-source-hashes.json

# Crash-recovery checkpoint (F17) — written per-article during synthesis, deleted on success.
# Machine-specific: committing would cause CI to incorrectly skip articles.
.kb-synthesis-progress.json

# Ingestion disk cache (F18) — sha256-keyed per-file parse cache for HTML/PDF files.
# Machine-specific: never commit. Each environment rebuilds its own cache on first run.
.kb-ingest-cache/

# Debug artefact — last compilation plan, for troubleshooting only.
.kb-debug-last-plan.json

