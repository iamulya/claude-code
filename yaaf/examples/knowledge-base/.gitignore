# Dependencies
node_modules/

# TypeScript build output
dist/

# KB compiled output — generated by the pipeline, not source material
kb/compiled/

# KB state files — auto-maintained, machine-specific
kb/.kb-registry.json
kb/.kb-lint-report.json

# Web clips — downloaded at runtime, often large
kb/raw/web-clips/

# Asset images downloaded during ingestion
kb/assets/

# Local env overrides
.env
.env.local
