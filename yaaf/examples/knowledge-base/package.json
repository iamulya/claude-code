{
  "name": "knowledge-base-yaaf-example",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "compile":  "npx tsx src/compile.ts",
    "compile:incremental": "npx tsx src/compile.ts --incremental",
    "lint":     "npx tsx src/compile.ts --lint-only",
    "lint:fix": "npx tsx src/compile.ts --lint-only --fix",
    "chat":     "npx tsx src/chat.ts",
    "demo":     "npx tsx src/chat.ts --demo",
    "start":    "npm run compile && npm run chat"
  },
  "dependencies": {
    "yaaf": "file:../../"
  },
  "devDependencies": {
    "tsx": "^4.7.0",
    "typescript": "^5.8.0"
  }
}
